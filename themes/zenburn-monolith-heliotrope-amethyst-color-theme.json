    "tokenColors": [
        {
            "name": "Comment",
            "scope": "comment",
            "settings": {
                "foreground": "#92bc91dd"
            }
        },
        {
            "name": "preprocessor",
            "scope": "meta.preprocessor, punctuation.definition.preprocessor",
            "settings": {
                "foreground": "#fbcb9edd"
            }
        },
        {
            "name": "phpdoc",
            "scope": "keyword.other.phpdoc",
            "settings": {
                "foreground": "#5d9953dd"
            }
        },
        {
            "name": "comment punctuation (/*, #, //)",
            "scope": "punctuation.definition.comment, punctuation.whitespace.comment",
            "settings": {
                "foreground": "#ade0aedd"
            }
        },
        {
            "name": "embedded ruby in string delimiters",
            "scope": "punctuation.section.embedded",
            "settings": {
                "foreground": "#949494dd"
            }
        },
        {
            "name": "embedded ruby in string",
            "scope": "source.ruby.embedded",
            "settings": {
                "foreground": "#dca0a1dd"
            }
        },
        {
